# ═══════════════════════════════════════════════════════════════════
# OpenMetadata — environment template
# Copy to .env and fill all values before running docker compose up.
# Never commit the real .env to version control.
# ═══════════════════════════════════════════════════════════════════

# ── MySQL ─────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_USER=openmetadata
MYSQL_PASSWORD=changeme_app

# ── Airflow / Ingestion ───────────────────────────────────────────
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=changeme_airflow

# ── OpenMetadata Server ───────────────────────────────────────────
# Public URL used for redirect URIs and link generation.
# Include the port if not behind a reverse proxy (e.g. http://localhost:8585).
OPENMETADATA_SERVER_URL=https://openmetadata.example.com

# ── Optional overrides (defaults are production-ready) ───────────
# OPENMETADATA_HEAP_OPTS=-Xmx2G -Xms2G
# AUTHORIZER_ADMIN_PRINCIPALS=[admin]
# AUTHENTICATION_PROVIDER=basic
